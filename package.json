{
  "name": "softech-smart-business-arabic",
  "version": "1.0.0",
  "description": "Arabic Softech Smart Business Mini Clone - Business Management System",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "server": "nodemon server/index.js",
    "client": "npm start --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "seed": "node server/seed.js",
    "docker:build": "docker build -t softech-business-arabic .",
    "docker:run": "docker run -p 5000:5000 softech-business-arabic",
    "docker:compose": "docker-compose up -d",
    "docker:compose:build": "docker-compose up -d --build"
  },
  "keywords": ["business", "management", "arabic", "erp", "inventory", "sales"],
  "author": "Softech Clone",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  }
}
