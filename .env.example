# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/softech_business_arabic
MONGO_USERNAME=admin
MONGO_PASSWORD=password
MONGO_DATABASE=softech_business_arabic

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# For Back4App Deployment
# Replace MONGODB_URI with your Back4App MongoDB connection string
# Example: mongodb://username:password@host:port/database
